{
  "name": "express",
  "description": "Fast, unopinionated, minimalist web framework",
  "version": "5.2.1",
  "license": "MIT",

  "engines": {
    "node": ">=18"
  },

  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",

    "test": "mocha test/ci.test.js",

    "test:ci": "npm run lint && npm run test",

    "test:coverage": "nyc --exclude examples --exclude test --exclude benchmarks --reporter=lcovonly --reporter=text npm test"
  },

  "devDependencies": {
    "mocha": "^10.7.3",
    "nyc": "^17.1.0",
    "eslint": "8.47.0",
    "supertest": "^6.3.0"
  }
}
